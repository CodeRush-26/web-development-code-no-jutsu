# === REQUIRED ===
# Get from https://console.groq.com → API Keys (free tier available)
GROQ_API_KEY=

# Optional — Groq model. Defaults to llama-3.3-70b-versatile (free, fast, supports tool-use)
GROQ_MODEL=llama-3.3-70b-versatile

# === OPTIONAL (defaults work for local dev) ===
PORT=3001
NODE_ENV=development

# Simulator tuning
TICK_MS=1000
SNAPSHOT_INTERVAL_MS=30000
HISTORY_TTL_HOURS=1

# Weather caching + thresholds (assumptions documented in README)
WEATHER_CACHE_MS=300000
ADVERSE_WAVE_HEIGHT_M=2.5
ADVERSE_WIND_WAVE_HEIGHT_M=2.0

# Fuel model (tons consumed per knot per hour at base burn)
BASE_FUEL_BURN_PER_KNOT_HOUR=0.5

# Proximity alert threshold (km)
PROXIMITY_THRESHOLD_KM=2.0

# Frontend origin (CORS). '*' allows any origin which is fine for hackathon demo.
CORS_ORIGIN=*
